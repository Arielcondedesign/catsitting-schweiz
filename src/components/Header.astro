---
import ThemeToggle from "./ThemeToggle.astro";
---

<header class="border-b border-primary-200 dark:border-primary-800">
  <div class="mx-auto flex max-w-5xl items-center justify-between px-4 py-5 sm:px-6 lg:px-8">
    <a href="/" class="flex items-center gap-3">
      <img
        src="/assets/logo.svg"
        alt="Ariel C_ND_"
        class="h-6 w-auto dark:hidden"
        width="264"
        height="32"
      />
      <img
        src="/assets/logo-dark.svg"
        alt="Ariel C_ND_"
        class="hidden h-6 w-auto dark:block"
        width="264"
        height="32"
      />
      <span class="sr-only">Katzensitting Schweiz — Ariel</span>
    </a>
    <div class="flex items-center gap-3">
      <ThemeToggle />
      <a
        href="#kontakt"
        aria-label="Kontakt aufnehmen"
        class="inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-primary-950 text-primary-50 transition hover:bg-primary-800 sm:h-auto sm:w-auto sm:gap-2 sm:px-5 sm:py-2.5 dark:bg-primary-50 dark:text-primary-950 dark:hover:bg-primary-200"
      >
        <svg
          class="h-5 w-5 sm:hidden"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2Z"></path>
          <polyline points="22 6 12 13 2 6"></polyline>
        </svg>
        <span class="hidden text-sm font-medium sm:inline">Kontakt aufnehmen</span>
      </a>
    </div>
  </div>
</header>
