---
interface Props {
  name: string;
  location: string;
  dates: string;
  duration: string;
  quote: string;
  highlight?: boolean;
}

const { name, location, dates, duration, quote, highlight = false } = Astro.props;
---

<figure
  class={`flex flex-col justify-between rounded-2xl border p-6 ${
    highlight
      ? "border-primary-950 bg-primary-950 text-primary-50 dark:border-primary-50 dark:bg-primary-50 dark:text-primary-950"
      : "border-primary-200 bg-white text-primary-900 dark:border-primary-800 dark:bg-primary-900 dark:text-primary-50"
  }`}
>
  <blockquote class="text-lg leading-relaxed">&laquo;{quote}&raquo;</blockquote>
  <figcaption class="mt-6">
    <p class="font-medium">{name}</p>
    <p class={highlight ? "text-primary-300 dark:text-primary-700" : "text-primary-500 dark:text-primary-400"}>
      {location} &middot; {dates}
    </p>
    <p
      class={`mt-2 inline-block rounded-full px-3 py-1 text-xs font-medium ${
        highlight
          ? "bg-primary-50 text-primary-950 dark:bg-primary-950 dark:text-primary-50"
          : "bg-primary-100 text-primary-700 dark:bg-primary-800 dark:text-primary-300"
      }`}
    >
      {duration}
    </p>
  </figcaption>
</figure>
